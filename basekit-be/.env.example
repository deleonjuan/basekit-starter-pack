# Server
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASS=root
DB_NAME=master

# Multitenancy
MULTITENANCY_ENABLED=true

# Rate limiting (ttl in seconds)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_TTL=900
THROTTLE_LOGIN_LIMIT=5

# JWT — replace both secrets with long random strings in production
JWT_SECRET=changeme_replace_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_refresh_replace_in_production
JWT_REFRESH_EXPIRES_IN=7d
